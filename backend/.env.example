APP_ENV=development
# Local: APP_PORT. Cloud (Render/Railway/Fly): they set PORT automatically.
APP_PORT=8080
# Prefer DATABASE_URL on cloud (Neon/Supabase). Or set discrete DB_* below.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-local-db-password
DB_NAME=krunchies
# Local: disable | Cloud Neon/Supabase: require
DB_SSLMODE=disable
JWT_SECRET=replace-with-a-strong-secret-min-16-chars
# Optional (not required to start the API)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
